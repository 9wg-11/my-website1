# EmailJS — https://dashboard.emailjs.com/admin/integration
# Copy this file to .env in THIS folder (project root) OR to client/.env — both are loaded.
# Restart the dev server after editing.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
